# inference-engine env (CONTRACTS section 9). Copy to .env; never commit real secrets.

# Hugging Face token with gated access to meta-llama/Llama-3.1-8B-Instruct.
HF_TOKEN=

# ClickHouse HTTP endpoint (banks + agent_steps). Engine reaches it on localhost.
CLICKHOUSE_URL=http://localhost:8123

# Manifest-dir fallback used only when ClickHouse is unreachable.
BANKS_DIR=../../banks

# HTTP + WS port (CONTRACTS section 9).
INFERENCE_PORT=8000

# Override the model id only for local experiments; the demo uses the default.
# MODEL_ID=meta-llama/Llama-3.1-8B-Instruct

# Attention kernel for the wrapped (non-MI) layers: sdpa (default) or eager.
# ATTN_IMPLEMENTATION=sdpa
