# Inference engine (CONTRACTS.md §9). Copy to .env and fill in. Never commit values.
HF_TOKEN=
# Optional model override; defaults to CONTRACTS §1 meta-llama/Llama-3.1-8B-Instruct.
# Keep in lockstep with the bank-compiler — banks are model-specific.
MODEL_ID=meta-llama/Llama-3.1-8B-Instruct
CLICKHOUSE_URL=http://localhost:8123
# Where the engine binds. The runner/console reach it via INFERENCE_URL.
INFERENCE_HOST=0.0.0.0
INFERENCE_PORT=8000
INFERENCE_URL=http://localhost:8000
# Fallback bank source if ClickHouse is unreachable at startup.
BANKS_DIR=../../banks
