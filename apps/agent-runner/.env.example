# Agent runner environment (CONTRACTS.md §9). Copy to .env and fill in.
# NEVER commit real values.

# Inference engine base URL. WS feed is derived from this.
INFERENCE_URL=http://localhost:8000

# ClickHouse for agent_steps logging (optional; runner degrades to in-memory).
CLICKHOUSE_URL=http://localhost:8123

# Required only if you install the [tokenizer] extra and want exact Llama
# token counts (gated model -> needs accepted Meta license).
HF_TOKEN=
